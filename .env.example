# Compass (G42 Core42) — mandatory for all agent LLM calls
OPENAI_API_KEY=your-compass-api-key-here
OPENAI_BASE_URL=https://compass.core42.ai/v1

# Model selection
# GPT-5.1 is used by Risk Analyst and Project Manager (complex reasoning, replanning)
# GPT-4.1 is used by Engineer, QA Agent, and Stakeholder (implementation and review)
COMPASS_MODEL=gpt-4.1
COMPASS_REASONING_MODEL=gpt-5.1
EMBEDDING_MODEL=text-embedding-3-large

# Sample / fallback mode
# false = live Compass calls for all agent decisions (recommended for demo)
# true  = deterministic SHA-256 hash fallback — all agents run, no LLM required
SAMPLE_MODE=false

# Server
API_PORT=8000
API_HOST=0.0.0.0
LOG_LEVEL=INFO
MAX_EXECUTION_ITERATIONS=5

# Timeout and retry limits
MAX_EXECUTION_SECONDS=900

# ── Real Public Data APIs (all optional — bundled data used when blank) ────────

# O*NET Web Services (free registration: https://services.onetcenter.org/developer/)
# Workforce intelligence: talent pool, demand, availability risk per technology.
# Bundled fallback: data/onet_tech_skills.json (O*NET 28.3, CC BY 4.0)
ONET_USERNAME=
ONET_PASSWORD=

# NIST NVD API key (free registration: https://nvd.nist.gov/developers/request-an-api-key)
# Raises rate limit from 5 req/30s to 50 req/30s. Blank = works without key.
NIST_API_KEY=
PUBLIC_API_TIMEOUT_SECONDS=10
MAX_QA_RETRIES=2
